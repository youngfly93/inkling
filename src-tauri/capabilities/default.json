{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for Inkling app windows",
  "windows": ["settings", "library", "actionbar"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "store:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select"
  ]
}
